# 제어 평면 PostgreSQL 접속 (부트스트랩 필수)
# app 스키마(groups/settings)가 위치하는 DB. asyncpg 드라이버 사용.
CONTROL_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ytdb

# 설정 시크릿 암호화 키 (32바이트 base64 url-safe)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# 그룹에 텔레그램 봇 토큰이 미설정일 때 사용할 기본 봇 (선택)
DEFAULT_TELEGRAM_BOT_TOKEN=

# 로그인 인증(단일 계정). AUTH_PASSWORD가 비어 있으면 인증 비활성(개발).
# 프로덕션에선 반드시 AUTH_PASSWORD를 설정해 로그인을 강제할 것.
AUTH_USERNAME=admin
AUTH_PASSWORD=
# 세션 쿠키 서명 키(비우면 FERNET_KEY에서 파생). 별도 지정 권장:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# https로 서비스하면 true(Secure 쿠키). http(Tailscale 등)면 false.
SESSION_HTTPS_ONLY=false

# 공유 페이지 링크 기본 URL (텔레그램 웹 공유 링크 첨부 시 필요)
# 예: https://ytdb.example.com  (끝 슬래시 없이)
# 비워두면 공유 링크가 메시지에 첨부되지 않음.
PUBLIC_BASE_URL=
